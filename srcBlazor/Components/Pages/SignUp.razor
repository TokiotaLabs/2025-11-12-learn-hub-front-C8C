@page "/sign-up"
@inject IStudentService StudentService
@rendermode InteractiveServer

<PageTitle>Sign Up - LearnHub</PageTitle>

<div class="flex overflow-hidden flex-col bg-white shadow-sm">
    <Header />

    <div class="max-w-[768px] mx-auto w-full p-16 mt-6 mb-6 bg-white rounded-lg shadow-md">
        <h2 class="text-2xl font-bold mb-4 text-indigo-500">Registro de Usuario</h2>

        <EditForm Model="@formData" OnValidSubmit="@HandleSubmit">
            <DataAnnotationsValidator />
            <ValidationSummary class="text-red-500 mb-4" />

            <div class="mb-4">
                <label class="block text-sm font-medium text-gray-700">Nombre completo</label>
                <InputText @bind-Value="formData.FirstName" class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm px-3 py-2" />
            </div>

            <div class="mb-4">
                <label class="block text-sm font-medium text-gray-700">Apellido</label>
                <InputText @bind-Value="formData.LastName" class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm px-3 py-2" />
            </div>

            <div class="mb-4">
                <label class="block text-sm font-medium text-gray-700">Fecha de nacimiento</label>
                <InputText @bind-Value="formData.DateOfBirth" type="date" class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm px-3 py-2" />
            </div>

            <div class="mb-4">
                <label class="block text-sm font-medium text-gray-700">Dirección de correo electrónico</label>
                <InputText @bind-Value="formData.Email" type="email" class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm px-3 py-2" />
            </div>

            @if (!string.IsNullOrEmpty(successMessage))
            {
                <div class="mb-4 p-3 bg-green-100 text-green-700 rounded-md">
                    @successMessage
                </div>
            }

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="mb-4 p-3 bg-red-100 text-red-700 rounded-md">
                    @errorMessage
                </div>
            }

            <button type="submit" id="submit-register" class="w-full bg-blue-500 text-white py-2 px-4 rounded-md cursor-pointer hover:bg-blue-600">
                Registrarse
            </button>
        </EditForm>
    </div>

    <Footer />
</div>

@code {
    private Student formData = new()
    {
        FirstName = "",
        LastName = "",
        Email = "",
        DateOfBirth = DateTime.Now.ToString("yyyy-MM-dd")
    };

    private string successMessage = string.Empty;
    private string errorMessage = string.Empty;

    private async Task HandleSubmit()
    {
        try
        {
            successMessage = string.Empty;
            errorMessage = string.Empty;

            await StudentService.CreateStudentAsync(formData);
            
            successMessage = "Registration successful!";
            
            // Reset form
            formData = new Student
            {
                FirstName = "",
                LastName = "",
                Email = "",
                DateOfBirth = DateTime.Now.ToString("yyyy-MM-dd")
            };
        }
        catch (Exception ex)
        {
            errorMessage = $"Error al registrar: {ex.Message}";
        }
    }
}
