@page "/"
@inject ICourseService CourseService
@rendermode InteractiveServer

<PageTitle>Home - LearnHub</PageTitle>

<div class="flex overflow-hidden flex-col bg-white shadow-sm">
    <Header />
    
    <!-- Hero Section -->
    <div class="flex overflow-hidden flex-col w-full text-white bg-neutral-800 max-md:max-w-full">
        <div class="flex relative flex-col w-full min-h-[640px] max-md:max-w-full">
            <img loading="lazy"
                 src="https://cdn.builder.io/api/v1/image/assets/TEMP/af42a541c37b1712a1396231dab07753cb7580a59bea72d76f4c768d7a2d7110?placeholderIfAbsent=true&apiKey=43f93c4c444042188d8c548c6db7827a"
                 alt="Students learning together"
                 class="object-cover absolute inset-0 size-full" />
            <div class="flex relative flex-col items-start px-20 pt-72 pb-32 w-full bg-opacity-40 max-md:px-5 max-md:py-24 max-md:max-w-full">
                <div class="flex flex-col items-start mb-0 max-w-full w-[791px] max-md:mb-2.5">
                    <h1 class="text-6xl font-bold leading-none max-md:max-w-full max-md:text-4xl">
                        Unlock Your Potential
                    </h1>
                    <p class="self-stretch mt-6 text-2xl text-gray-100 max-md:max-w-full">
                        Empowering you with diverse courses for every passion and skill level.
                    </p>
                    <a href="/courses"
                       class="overflow-hidden px-5 py-3 mt-6 text-lg leading-loose bg-indigo-500 rounded-md border border-solid border-black border-opacity-0">
                        <p class="text-white">Explore Courses</p>
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Courses Section -->
    <section class="flex flex-col justify-center items-center px-20 py-14 w-full bg-white max-md:px-5 max-md:max-w-full">
        <div class="flex flex-col w-full max-w-[1176px] max-md:max-w-full">
            <h2 class="self-center text-2xl text-black">Popular Courses</h2>
            @if (isLoading)
            {
                <div class="text-center mt-5">Loading courses...</div>
            }
            else if (courses.Any())
            {
                <div class="grid grid-cols-2 max-md:grid-cols-1 gap-5 mt-5">
                    @foreach (var course in courses)
                    {
                        <CourseCard Course="@course" OnChange="@LoadCourses" />
                    }
                </div>
            }
            else
            {
                <div class="text-center mt-5 text-gray-500">No courses available</div>
            }
        </div>
    </section>

    <!-- Testimonial Section -->
    <section class="flex flex-col justify-center items-center px-16 py-24 w-full bg-white max-md:px-5 max-md:max-w-full">
        <div class="w-full max-w-[1144px] max-md:max-w-full">
            <Testimonial Quote="@testimonial.Quote"
                        Name="@testimonial.Name"
                        Role="@testimonial.Role"
                        ImageUrl="@testimonial.ImageUrl" />
        </div>
    </section>

    <Footer />
</div>

@code {
    private List<Course> courses = new();
    private bool isLoading = true;
    private TestimonialData testimonial = new()
    {
        Quote = "LearnHub has transformed my career! The courses are well-structured and the community support is outstanding.",
        Name = "Emily Johnson",
        Role = "Software Developer",
        ImageUrl = "https://cdn.builder.io/api/v1/image/assets/TEMP/e922464baea409103a49400a49011315ce9211ace6b214a6000dcd7d7c6995f6?placeholderIfAbsent=true&apiKey=43f93c4c444042188d8c548c6db7827a"
    };

    protected override async Task OnInitializedAsync()
    {
        await LoadCourses();
    }

    private async Task LoadCourses()
    {
        isLoading = true;
        var result = await CourseService.GetCoursesAsync();
        courses = result.ToList();
        isLoading = false;
    }
}
