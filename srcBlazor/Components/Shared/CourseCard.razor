@inject ICourseService CourseService
@inject ILogger<CourseCard> Logger

@* Course card component displaying course information with edit/delete actions *@

<Modal IsOpen="@isModalOpen" 
       OnClose="@(() => isModalOpen = false)" 
       OnAction="@HandleDeleteConfirm"
       Title="Eliminar Curso">
    <p class="text-indigo-500 text-center font-medium text-lg">
        ¿Estás seguro que quieres eliminar el curso?
    </p>
</Modal>

<div id="course-card" class="grow p-4 w-full bg-white rounded-md shadow-sm max-md:mt-6 max-md:max-w-full">
    <div class="flex gap-5 max-md:flex-col">
        <div class="flex flex-col w-[69%] max-md:ml-0 max-md:w-full">
            <div class="flex flex-col grow items-start text-sm max-md:mt-10">
                <div class="text-xl text-zinc-900">
                    @Course.Title
                </div>
                <div class="self-stretch mt-2 leading-6 text-zinc-400">
                    @Course.Description
                </div>
                <a href="@($"/courses/detail/{Course.Id}")"
                   class="overflow-hidden px-3 py-2 mt-10 leading-loose text-indigo-500 bg-white rounded-md border border-indigo-500 border-solid max-md:mt-10">
                    Enroll Now
                </a>
            </div>
        </div>
        <div class="flex flex-col ml-5 w-[31%] max-md:ml-0 max-md:w-full">
            <img loading="lazy"
                 src="@ImageUrl"
                 alt="@($"{Course.Title} course thumbnail")"
                 class="object-contain grow shrink-0 w-40 max-w-full rounded aspect-[1.08] max-md:mt-10" />
        </div>
    </div>
    <div class="flex justify-end mt-6 gap-2">
        <a href="/new" class="cursor-pointer">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#e2a703" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/>
            </svg>
        </a>
        <button class="cursor-pointer" @onclick="@(() => isModalOpen = true)">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="red" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M3 6h18"/>
                <path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/>
                <path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/>
            </svg>
        </button>
    </div>
</div>

@code {
    [Parameter]
    public Course Course { get; set; } = new();

    [Parameter]
    public string ImageUrl { get; set; } = "https://picsum.photos/id/2/200/300";

    [Parameter]
    public EventCallback OnChange { get; set; }

    private bool isModalOpen = false;

    private async Task HandleDeleteConfirm()
    {
        try
        {
            await CourseService.DeleteCourseAsync(Course.Id);
            isModalOpen = false;
            await OnChange.InvokeAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error al eliminar el curso");
        }
    }
}
