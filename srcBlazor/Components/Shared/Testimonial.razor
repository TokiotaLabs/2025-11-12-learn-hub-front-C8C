@* Testimonial component for displaying user testimonials *@

<div class="flex gap-5 max-md:flex-col">
    <div class="flex flex-col w-[28%] max-md:ml-0 max-md:w-full">
        <img loading="lazy"
             src="@ImageUrl"
             alt="@($"{Name}'s testimonial")"
             class="object-contain grow shrink-0 max-w-full rounded-2xl aspect-[0.9] w-[280px] max-md:mt-10" />
    </div>
    <div class="flex flex-col ml-5 w-[72%] max-md:ml-0 max-md:w-full">
        <div class="flex flex-col self-stretch my-auto w-full max-md:mt-10 max-md:max-w-full">
            <img loading="lazy"
                 src="https://cdn.builder.io/api/v1/image/assets/TEMP/819d2af2f70dfbf12acc40e8c8af2786870ec6ed5a7c57b171a94c84796cdbb0?placeholderIfAbsent=true&apiKey=43f93c4c444042188d8c548c6db7827a"
                 alt=""
                 class="object-contain max-w-full aspect-[5] w-[180px]" />
            <div class="mt-8 mr-8 text-xl leading-8 text-zinc-900 max-md:mr-2.5 max-md:max-w-full">
                @Quote
            </div>
            <div class="flex flex-wrap gap-10 mt-20 w-full max-md:mt-10 max-md:max-w-full">
                <div class="flex flex-col flex-1">
                    <div class="self-start text-xl font-bold text-zinc-900">
                        @Name
                    </div>
                    <div class="text-lg leading-loose text-zinc-400">
                        @Role
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public string Quote { get; set; } = string.Empty;

    [Parameter]
    public string Name { get; set; } = string.Empty;

    [Parameter]
    public string Role { get; set; } = string.Empty;

    [Parameter]
    public string ImageUrl { get; set; } = string.Empty;
}
